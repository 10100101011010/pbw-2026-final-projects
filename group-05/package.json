{
  "name": "gtgs",
  "version": "1.0.0",
  "private": true,
  "description": "Gunadarma Thesis Guidance Scheduling System",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client",
    "lint": "npm run lint --workspace server && npm run lint --workspace client",
    "test": "npm run test --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "seed": "npm run seed --workspace server"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2"
  }
}
